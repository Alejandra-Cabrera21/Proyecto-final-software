# ── Base de datos ─────────────────────────────────────────────────────────────
# Obtener desde Supabase: Settings > Database > Connection string (URI mode)
DATABASE_URL="postgresql://usuario:password@host:5432/microencuestas"

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Clave secreta larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET="cambia-esto-por-una-clave-secreta-muy-larga"
JWT_EXPIRES_IN="7d"

# ── Frontend ──────────────────────────────────────────────────────────────────
# En producción: URL de Vercel
FRONTEND_URL="http://localhost:5173"

# ── Monitoreo (Sentry) ────────────────────────────────────────────────────────
# Obtener desde sentry.io > Settings > Projects > Client Keys (DSN)
# Dejar vacío en desarrollo para desactivar
SENTRY_DSN=""

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000